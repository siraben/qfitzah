; The rule pattern spans physical lines.
(Pair
  x
  y) (Cons x y)

; The expression spans physical lines too.
(Pair
  A
  B)

; Parentheses in comments must not affect record balancing.
(Id
  z) z ; )
(Id
  OK)

; A full rule can also be written as a single parenthesized directive whose
; pattern and replacement are both multi-line forms.
(Rule
  (Wrap
    x)
  (Box
    x))
(Wrap
  Gift)
