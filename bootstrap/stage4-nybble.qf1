; First real runtime-subsystem compilation target.
;
; This is the nybble routine from qfitzah.s in staged-source form:
;   al -= '0'
;   if al > 9: al -= 7
;
; The staged compiler uses EBX as the value register.  Start loads the input
; byte from static data, calls Nybble, then exits with the computed value.
(QfcAssemble (Source Start (Def Start NoFrame (Seq (LoadByteEbx Digit) (Seq (CallProc Nybble) (ExitReg Ebx))) (Def Nybble NoFrame (Seq (SubEbx 30) (Seq (CmpEbx 09) (IfBelowEq Done (Nop) (SubEbx 07)))) (Data Digit 41 End)))))
